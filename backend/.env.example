# Servidor
PORT=3333
NODE_ENV=development

# Banco (mesmo do docker-compose / database/.env)
DATABASE_URL="postgresql://ams:ams_dev_password@localhost:5432/ams_helpme?schema=public"

# JWT — troque por valores aleatórios longos em produção
JWT_ACCESS_SECRET="dev_access_secret_change_me"
JWT_REFRESH_SECRET="dev_refresh_secret_change_me"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN_DAYS=7

# Frontend autorizado (CORS)
CORS_ORIGIN="http://localhost:5173"

# Cookie do refresh token
COOKIE_SECURE=false
